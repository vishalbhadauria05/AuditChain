# Environment
NODE_ENV=development

# Server
PORT=5000

# MongoDB (REQUIRED)
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/auditchain
# MongoDB Atlas (Cloud - Recommended):
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/auditchain?retryWrites=true&w=majority

# JWT Secret (REQUIRED - Generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Blockchain Configuration (REQUIRED)
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
PRIVATE_KEY=

# IPFS - Pinata Configuration (REQUIRED)
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
PINATA_API_URL=https://api.pinata.cloud
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# Optional: Gas Configuration
GAS_LIMIT=3000000
GAS_PRICE=20000000000
